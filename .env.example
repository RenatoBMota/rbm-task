# Database
POSTGRES_DB=rbmtask
POSTGRES_USER=rbm
POSTGRES_PASSWORD=rbmpassword

# Redis
REDIS_PASSWORD=rbmredis

# MinIO
MINIO_ROOT_USER=rbmadmin
MINIO_ROOT_PASSWORD=rbmminiopass

# Backend
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development

# SMTP (opcional - deixe em branco para desativar o envio de e-mails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@rbmtask.com
SMTP_FROM_NAME=RBM TASK

# xAI Grok (opcional - deixe em branco para desativar a extração de tarefas por IA)
XAI_API_KEY=
XAI_MODEL=grok-4-fast

# Frontend
NEXT_PUBLIC_API_URL=https://task.renatomota.online
